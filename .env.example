# Copy this file to .env.local for local development.
# On Vercel, add the same variables under Project Settings -> Environment Variables.

# --- Contact form (custom node:net / node:tls SMTP client) ---------------
#
# Recommended free option: Gmail SMTP with an "App Password".
# 1. Enable 2-Step Verification on the Gmail account:
#    https://myaccount.google.com/security
# 2. Create an App Password:
#    https://myaccount.google.com/apppasswords
# 3. Use that 16-character app password as SMTP_PASS below (NOT your
#    normal Gmail password).

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# 587 = STARTTLS (recommended, pairs with SMTP_SECURE=false)
# 465 = implicit TLS (pairs with SMTP_SECURE=true)
SMTP_PORT=587
SMTP_SECURE=false

# The mailbox that authenticates and sends the message
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your16charapppassword

# Optional: domain announced in the SMTP EHLO command (any value works
# for Gmail; defaults to "localhost")
SMTP_EHLO_DOMAIN=localhost

# Optional: where contact-form messages are delivered.
# Defaults to SMTP_USER if not set.
CONTACT_TO_EMAIL=youraddress@gmail.com

# --- Site metadata ---------------------------------------------------------

# Used for canonical URLs, sitemap.xml and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
